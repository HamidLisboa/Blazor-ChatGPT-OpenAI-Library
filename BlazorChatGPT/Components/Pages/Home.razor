    #region [03] Chat Completion method - streaming mode
    private async void AskOpenAIStreamingAsync()
    {
        if (!string.IsNullOrEmpty(_userInput))
        {
            _myPrompt += _userInput + "\n";
            dialogs.Add(new Dialog { MessageText = _myPrompt, IsPrompt = true });
            _userInput = string.Empty;
            dialogs.Add(new Dialog { 
                    MessageText = "", 
                    IsPrompt = false });
            lastDialog = dialogs.LastOrDefault();
            var response = GPTService.GetStreamingResponseAsync(_myPrompt);
            await foreach(StreamingChatCompletionUpdate completionUpdate in response)
            {
                if(completionUpdate.ContentUpdate.Count>0)
                {
                    lastDialog.MessageText += completionUpdate.ContentUpdate[0].Text;
                    lastDialog.MessageText = ConvertMarkdownToHtml(lastDialog.MessageText);
                    //lastDialog.MessageText = ConvertMarkdownToHtml(completionUpdate.ContentUpdate[0].Text);
                    StateHasChanged();
                    Thread.Sleep(100);
                    await JSRuntime.InvokeVoidAsync("scrollToBottom");
                }
                if (completionUpdate.FinishReason != null)
                {
                    lastDialog.MessageText += "<br/>";
                    lastDialog.MessageText += $"<p style=´color: blue;´><b>Response Finished Reason: {completionUpdate.FinishReason}</b></p>";
                    lastDialog.MessageText += "<hr/>";
                    StateHasChanged();
                    Thread.Sleep(100);
                    await JSRuntime.InvokeVoidAsync("scrollToBottom");
                }
            }
            
            
        }
    }
    #endregion
