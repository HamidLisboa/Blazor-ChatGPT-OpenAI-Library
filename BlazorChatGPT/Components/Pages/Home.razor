@page "/"
@inject Services.GPTService GPTService
@using OpenAI.Chat;
@using OpenAI.Images;
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>OpenAI GPT!</PageTitle>

<h1>Ask OpenAI GPT!</h1>

<div class="chat-container modal-dialog-scrollable">
    <div class="chat-messages">
        @foreach (var dialog in dialogs)
        {
            <div class="chat-message @(dialog.IsPrompt ? "user-message" : "bot-message")">
                @if (dialog.IsPrompt)
                {
                    // The dialog.MessageText is the user input
                    <span class="message-text">@dialog.MessageText</span>
                    <img src="images/User.webp" class="message-icon" alt="User icon" />
                }
                else
                {
                    // The dialog.MessageText is the bot response
                    <img src="images/Robot.webp" class="message-icon" alt="Bot icon" />
                    if (!string.IsNullOrEmpty(dialog.ImageUri))
                    {
                        
                            <img src="@dialog.ImageUri" style="width:200px; height:auto;" alt="Generated image" 
                            @onclick="() => OpenModal(dialog.ImageUri)" />
                        
                    }
                    else{
                        <span class="message-text">@((MarkupString)dialog.MessageText)</span>
                    }
                }
    )
            </div>
        }
    </div>
    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
    <br />
    
    <div class="chat-input">
        <textarea rows="1" cols="5" type="text" @bind="_userInput" placeholder="Input your prompt here..." />
        <label class="btn-info" style="margin-left:8px; margin-right:8px; display:inline-flex; align-items:center;">
            <input type="checkbox" @bind="isImageMode" />
            <span>Image mode</span>
        </label>
        

        <button @onclick="OnAskClicked">Ask</button>
        @* <button @onclick="GenerateImageBytesAsync">Send</button> *@
    </div>
    
</div>
<ImageModal IsOpen="@isModalOpen" ImageSrc="@modalImageSrc" OnClose="CloseModal" />
@code{
    #region [00] Shared Variables
    private string _userInput = string.Empty;
    private bool isImageMode = false;
    private string _botResponse = string.Empty;
    private string _myPrompt = string.Empty;
    List<Dialog> dialogs = new List<Dialog>();
    private Dialog lastDialog = null;
    private bool _isLoading;
    private Timer _timer;
    private bool isModalOpen = false;
    private string? modalImageSrc;
    List<ChatMessage> chatHistory = new();

    #endregion
    #region [01] Shared Methods and Classes
    private class Dialog
    {
        public string MessageText { get; set; }
        public bool IsPrompt { get; set; } = true;
        public string? ImageUri { get; set; }
    }
    private string ConvertMarkdownToHtml(string message)
    {
        string html = message;
        html = Regex.Replace(html, @"\*\*(.+?)\*\*", "<b>$1</b>"); // Bold
        html = Regex.Replace(html, @"\*(.+?)\*", "<i>$1</i>"); // Italic
        html = Regex.Replace(html, @"\`(.+?)\`", "<code>$1</code>"); // Inline code
        html = Regex.Replace(html, @"\n\s*\n", "</p><p>"); // Paragraphs
        html = Regex.Replace(html, @"\n", "<br>"); // New lines
        html = Regex.Replace(html, @"(?m)^# (.+)", "<h1>$1</h1>"); // Headers
        html = Regex.Replace(html, @"(?m)^## (.+)", "<h2>$1</h2>"); // Headers
        html = Regex.Replace(html, @"(?m)^### (.+)", "<h3>$1</h3>"); // Headers
        html = Regex.Replace(html, @"(?:!)\[(?<alt>[^\]]+)\]\((?:sandbox:)?(?<path>[^)]+)\)",
                "<img src=\"${path}\" alt=\"${alt}\" onclick=\"openModalFromJs('${path}')\" />");//Images
        return html;
    }
    protected override void OnInitialized()
    {
        _timer = new Timer(UpdateLoadingDots, null, Timeout.Infinite, 1000);
    }
    private void UpdateLoadingDots(object state)
    {
        if (_isLoading && lastDialog != null)
        {
            
            if (lastDialog.MessageText.EndsWith("..."))
            {
                lastDialog.MessageText = lastDialog.MessageText.Substring(0, lastDialog.MessageText.Length - 3);
            }
            else
            {
                lastDialog.MessageText += ".";
            }
            InvokeAsync(StateHasChanged);
            
        }
    }
    public void Dispose()
    {
        _timer?.Dispose();
    }
    #endregion

    #region [02] Chat Completion method - streaming mode
   
    private async void AskOpenAIStreamingAsync()
    {
        if (!string.IsNullOrEmpty(_userInput))
        {
            _myPrompt += _userInput + "\n";
            dialogs.Add(new Dialog { MessageText = _myPrompt, IsPrompt = true });
            _userInput = string.Empty;
            dialogs.Add(new Dialog { 
                    MessageText = "", 
                    IsPrompt = false });
            lastDialog = dialogs.LastOrDefault();
            chatHistory.Add(ChatMessage.CreateUserMessage(_myPrompt));
            var response = GPTService.GetStreamingResponseAsync(chatHistory);
            await foreach(StreamingChatCompletionUpdate completionUpdate in response)
            {
                if(completionUpdate.ContentUpdate.Count>0)
                {
                    lastDialog.MessageText += completionUpdate.ContentUpdate[0].Text;
                    lastDialog.MessageText = ConvertMarkdownToHtml(lastDialog.MessageText);
                    //lastDialog.MessageText = ConvertMarkdownToHtml(completionUpdate.ContentUpdate[0].Text);
                    _myPrompt = string.Empty;
                    StateHasChanged();
                    await JSRuntime.InvokeVoidAsync("scrollToBottom"); 
                    Thread.Sleep(100);
                    
                }
                if (completionUpdate.FinishReason != null)
                {
                    chatHistory.Add(ChatMessage.CreateAssistantMessage(lastDialog.MessageText));
                    lastDialog.MessageText += "<br/>";
                    lastDialog.MessageText += $"<p style=´color: blue;´><b>Response Finished Reason: {completionUpdate.FinishReason}</b></p>";
                    lastDialog.MessageText += "<hr/>";
                    _myPrompt = string.Empty;
                    StateHasChanged();
                    Thread.Sleep(100);
                    await JSRuntime.InvokeVoidAsync("scrollToBottom");
                }
            }
        }
    }
    #endregion
    #region [03] Image Generation method
    
    private async void GenerateImageUriAsync()
    {
        _myPrompt += _userInput + "\n";
        dialogs.Add(new Dialog { MessageText = _myPrompt, IsPrompt = true, ImageUri = null });
        _userInput = string.Empty;
        _isLoading = true;
        _timer.Change(0, 1000);
        dialogs.Add(new Dialog
        {
            MessageText = "",
            IsPrompt = false,
            ImageUri = null
        });
        lastDialog = dialogs.LastOrDefault();
        lastDialog.MessageText = "Generating image...";
        GeneratedImage image = await GPTService.GenerateImageToUriAsync(_myPrompt);
        _isLoading = false;
        _timer.Change(Timeout.Infinite, Timeout.Infinite);
        lastDialog.ImageUri = image.ImageUri.ToString();
        lastDialog.MessageText = image.RevisedPrompt;
        StateHasChanged();
        
    }
    
    private async void GenerateImageBytesAsync()
    {
        _myPrompt += _userInput + "\n";
        dialogs.Add(new Dialog { MessageText = _myPrompt, IsPrompt = true, ImageUri = null });
        _userInput = string.Empty;
        _isLoading = true;
        _timer.Change(0, 1000);
        dialogs.Add(new Dialog
        {
            MessageText = "",
            IsPrompt = false,
            ImageUri = null
        });
        lastDialog = dialogs.LastOrDefault();
        lastDialog.MessageText = "Generating image...";
        GeneratedImage image = await GPTService.GenerateImageToBytesAsync(_myPrompt);
        _isLoading = false;
        _timer.Change(Timeout.Infinite, Timeout.Infinite);
        lastDialog.ImageUri = $"data:image/png;base64,{Convert.ToBase64String(image.ImageBytes)}";
        lastDialog.MessageText = image.RevisedPrompt;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("scrollToBottom");
    }
    private void OpenModal(string imageSrc)
    {
        modalImageSrc = imageSrc;
        isModalOpen = true;
        
    }
    private void CloseModal()
    {
        modalImageSrc = null;
        isModalOpen = false;
    }
    private async Task OnAskClicked()
    {
        // If there's no user input, do nothing
        if (string.IsNullOrWhiteSpace(_userInput))
        {
            return;
        }

        // Normalize input
        _userInput = _userInput.Trim();

        // Explicit UI control: use the Image Mode checkbox to route the request
        if (isImageMode)
        {
            GenerateImageBytesAsync();
        }
        else
        {
            AskOpenAIStreamingAsync();
        }
    }
    #endregion
}